{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information",
      "Microsoft.EntityFrameworkCore.Database.Command": "Debug"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Use environment variable DATABASE_CONNECTION_STRING"
  },
  "Redis": {
    "ConnectionString": "REDIS_CONNECTION_STRING"
  },
  "JwtSettings": {
    "SecretKey": "Use environment variable JWT_SECRET_KEY",
    "Issuer": "http://skylabidp-service",
    "Audience": {
      "SkyLabmgm": "http://skylabmgm-service",
      "SkyLabdevelop": "http://skylabmgm-service"
    },
    "TokenExpiryInMinutes": 120,
    "AccessTokenExpiryInMinutes": 60,
    "RefreshTokenExpiryInDays": 7,
    "RsaPrivateKey": "Use environment variable JWT_RSA_PRIVATE_KEY"
  },
  "CookieSettings": {
    "Domain": "",
    "ExpireMinutes": 1440
  },
  "MailSettings": {
    "EmailFrom": "skyhsieh@skylab.com.tw",
    "SmtpHost": "mailgw.skylab.com.tw",
    "SmtpPort": 25,
    "SmtpUser": "",
    "SmtpPass": "",
    "DisplayName": "",
    "SmtpUseSSL": false,
    "PgEmail": "skyhsieh@skylab.com.tw",
    "AssigneeEmail": "skyhsieh@skylab.com.tw"
  },
  "AllowCorsWebSites": [
    "http://localhost:5173",
    "http://localhost:8098",
    "http://localhost:8089"
  ],
  "_CorsComment": "⚠️ 警告：生產環境不可使用 localhost。請在 appsettings.Production.json 中覆寫此設定",
  "AllowedHosts": "*",
  "PasswordLimitDays": 90,
  "ApiKey": "Use environment variable",
  "AuditLog": {
    "FileSettings": {
      "Enabled": true,
      "FilePath": "./Logs/AuditLogs",
      "FileName": "audit_.json",
      "RollingInterval": "Day",
      "RetainedFileCountLimit": 31
    },
    "DatabaseSettings": {
      "Enabled": true
    },
    "ExcludedPaths": [
      "/SystemInfos",
      "/health",
      "/metrics",
      "/swagger",
      "/favicon.ico"
    ]
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.File"
    ],
    "Filter": [
      {
        "Name": "ByExcluding",
        "Args": {
          "expression": "Contains(@Message, 'Password')"
        }
      }
    ],
    "MinimumLevel": {
      "Default": "Verbose",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning",
        "Microsoft.Hosting.Lifetime": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/log.txt",
          "rollingInterval": "Day",
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} {CorrelationId} {Level:u3}] {Username} {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/log_.json",
          "rollingInterval": "Day",
          "formatter": "Serilog.Formatting.Json.JsonFormatter, Serilog"
        }
      },
      {
        "Name": "Seq",
        "Args": {
          "serverUrl": "http://localhost:5341"
        }
      },
      {
        "Name": "Logger",
        "Args": {
          "configureLogger": {
            "WriteTo": [
              {                "Name": "File",
                "Args": {
                  "path": "Logs/AuditLogs/audit_.json",
                  "rollingInterval": "Day",
                  "formatter": "Serilog.Formatting.Json.JsonFormatter, Serilog"
                }
              }
            ],
            "Filter": [
              {
                "Name": "ByIncludingOnly",
                "Args": {
                  "expression": "Contains(SourceContext, 'Audit')"
                }
              }
            ]
          }
        }
      }
    ],
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithThreadId",
      "WithExceptionDetails"
    ],
    "Properties": {
      "Application": "SkyLabIdp"
    }
  },
  "DataProtection": {
    "Purpose": "6CJeFE6yCrWDBhk5rmqrxlTUwJVytoq2HJGc3bSOzkr1mrCkR2w7QRmSxGwZkq6axuIi63ZTDx6ZpM0jIcw6MJdbKJ6FZwjZXLtpttl7dPaCWEiHvcY9i9wo55ZSfmLa7amDdl0rzuo91bwRhQ48fOJtb3BhaXjyjFrhP8VELzzuPObrACKZ3jaw8ycqSkYkQ3IaU3HS8ezm04UVi1SPHFrGf5TWHJtYR0sbhBWiA09GqqZDaHT9yhLAAyOmM4P",
    "EncryptInDevelopment": false
  },
  "Captcha": {
    "AudioFilesPath": "./audio",
    "EnableCaptcha": "false"
  },
  "TenantResetPasswordUrls": {
    "SkyLabmgm": "https://skylab.skylab.com.tw/skylabmgm/reset-password",
    "SkyLabdevelop": "https://develop.skylab.com.tw:3701/skylabdevelop/reset-password"

  },
  "Security": {
    "AllowedResetPasswordDomains": [
      "skylab.skylab.com.tw",
      "develop.skylab.com.tw",
      "*.skylab.com.tw",
      "idp.skylab.com.tw"
    ],
    "_comment": "🔒 URL 白名單 - 僅允許這些域名用於密碼重設 URL (SSRF 防護)"
  },
  "ResetPasswordUrl": "http://localhost/forget-password",
  "PgEmail": "skyhsieh@skylab.com.tw",
  "AssigneeEmail": "skyhsieh@skylab.com.tw",
  "RateLimiting": {
    "ShortTerm": {
      "PermitLimit": 50,
      "WindowSeconds": 2
    },
    "LongTerm": {
      "PermitLimit": 100,
      "WindowSeconds": 30
    },
    "Authentication": {
      "PermitLimit": 5,
      "WindowSeconds": 60,
      "_comment": "登入/註冊端點的嚴格速率限制：每分鐘最多 5 次請求"
    },
    "RefreshToken": {
      "PermitLimit": 5,
      "WindowSeconds": 60,
      "_comment": "Refresh Token 端點專門的嚴格速率限制：每分鐘最多 5 次請求"
    },
    "FileUpload": {
      "PermitLimit": 10,
      "WindowSeconds": 60,
      "_comment": "文件上傳端點的速率限制：每分鐘最多 10 次請求"
    }
  },
  "FileUploadSettings": {
    "SkyLabDocUserDetailFilesFloderPath": "./Uploads/SkyLabDocUserDetailFiles/",
    "MaxFileSizeInMB": 5,
    "_comment": "文件大小限制：最大 5MB"
  },
  "AppSettings": {
    "BaseUrl": "http://localhost",
    "FrontendUrl": "http://localhost"
  },
  "ExternalLogin": {
    "_comment": "🔒 安全設定：所有環境都使用環境變數，不在此檔案設定敏感資料",
    "_requiredEnvVars": [
      "OAUTH_GOOGLE_DEFAULT_CLIENT_ID",
      "OAUTH_GOOGLE_DEFAULT_CLIENT_SECRET"
    ],
    "_instructions": "請設定上述環境變數來配置 OAuth。參考：doc/OAuth_Environment_Variables.md"
  },
  "LoginNotification": {
    "EnableNotification": true,
    "DevelopmentEmailOverride": {
      "Enabled": true,
      "Recipients": [
        "skyhsieh@skylab.com.tw"
      ]
    },
    "TenantConfigurations": {
      "SkyLabmgm": {
        "Subject": "SkyLab管理系統登入通知",
        "TemplateName": "SkyLabmgmLoginNotification",
        "EnableSuccessNotification": true,
        "EnableFailureNotification": true
      },
      "SkyLabdevelop": {
        "Subject": "SkyLab開發單位系統登入通知",
        "TemplateName": "SkyLabdevelopLoginNotification",
        "EnableSuccessNotification": true,
        "EnableFailureNotification": true
      }

    }
  }
}